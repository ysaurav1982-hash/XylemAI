}

/* ---------- AI Message ---------- */

.ai{

    align-self:flex-start;

    max-width:78%;

    padding:14px 18px;

    margin:8px 0;

    background:#1B1B1B;

    color:#F5F5F5;

    border:1px solid rgba(0,255,120,.15);

    border-radius:22px 22px 22px 8px;

    line-height:1.6;

    font-size:15px;

    word-break:break-word;

    animation:slideAI .25s ease;

}

